  m_Script: {fileID: 11500000, guid: 69c5666ef3490414ba3aae7b451a283a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager
  questions:
  - questionText: Ay salamat at dumating ka. Medyo hibahib na ako sa dami ng pasyente
      ngay-on." Ano ang ibig sabihin ng hibahib?
    choices:
    - Busog
    - Masaya
    - Pagod
    - Antok
    correctAnswerIndex: 2
  - questionText: Pakitulungan nga ako. I-bulwasin mo nga areng lumang swero at itapon
      sa tamang basurahan." Ano ang bulwasin?
    choices:
    - Ikapit
    - Tanggalin
    - Linisin
    - Itago
    correctAnswerIndex: 1
  - questionText: Dahan-dahan laang, baka ika'y ma-sinanggi ng mga dumadaan na stretcher."
      Ano ang sinanggi?
    choices:
    - Masagit ng hindi sinasadya
    - Masuntok
    - Matulak
    - Maapakan
    correctAnswerIndex: 0
  - questionText: Medyo mabanas ngay-on, pakibuksan nga 'yaang tanghudan para humangin."
      Ano ang tanghudan?
    choices:
    - Pintuan
    - Electric Fan
    - Cabinet
    - Bintana
    correctAnswerIndex: 3
  - questionText: Pag-uwi mo, mag-hinaw ka agad ng kamay at paa para hindi ka magdala
      ng sakit sa bahay." Ano ang hinaw?
    choices:
    - Matulog nang mahimbing
    - Kumain ng hapunan
    - Magbihis ng damit
    - Maglinis/Maghugas ng kamay o paa
    correctAnswerIndex: 3
  tutorialQuestions: []
