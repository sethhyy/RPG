  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 69c5666ef3490414ba3aae7b451a283a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager
  questions:
  - questionText: Ay naku! Nakaka-adwa naman 'yaang si Totoy, masyadong bargas magsalita
      sa suki." Ano ang ibig sabihin ng adwa?
    choices:
    - Naiinis
    - Natutuwa
    - Nahihiya
    - Napapagod
    correctAnswerIndex: 0
  - questionText: Dine ka bumili sa akin. Areng apalya ko'y hindi mukarhat ang lasa."
      Ano ang mukarhat (o makarhat)?
    choices:
    - Masyadong matamis
    - Maalat
    - Mapakla
    - Malinamnam
    correctAnswerIndex: 2
  - questionText: Bakit ka ga balais d'yan? Para kang tinitigasan ng kisig sa binti."
      Ano ang kisig sa kontekstong Batangas?
    choices:
    - Sugat
    - Tato
    - Alahas
    - Pulikat
    correctAnswerIndex: 3
  - questionText: Ay, tila ika'y baysak na ng pawis! Mag-paspase ka na at baka ika'y
      abutan ng ulan." Ano ang ibig sabihin ng paspase?
    choices:
    - Bagalan
    - Bilisan
    - Tumigil
    - Maglaho
    correctAnswerIndex: 1
  - questionText: Sige, yayao ka na ga? Ingat sa pag-liban sa kalsada, madaming sasakyan."
      Ano ang liban?
    choices:
    - Pag-absent
    - Pagtakbo
    - Paghinga
    - Pagtawid
    correctAnswerIndex: 1
  tutorialQuestions: []
  quizPanel: {fileID: 1668176923}
  questionText: {fileID: 1668176922}
  answerButtons:
