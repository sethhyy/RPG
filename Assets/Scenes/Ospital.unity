  m_Script: {fileID: 11500000, guid: 69c5666ef3490414ba3aae7b451a283a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager
  questions:
  - questionText: Hoy! Dine ang daan, 'wag d'yan sa harap ng ambulansya! Baka ika'y
      ma-sungaba sa kanal." Ano ang sungaba?
    choices:
    - Mahulog sa tubig
    - Masubsob/madapa
    - Makatulog
    - Tumalon
    correctAnswerIndex: 1
  - questionText: Mag-abange ka laang d'yan sa gilid ng tarangkahan. Bawal ang harang
      sa daan." Ano ang tarangkahan?
    choices:
    - Gate
    - Pintuan sa loob
    - Binatana
    - Kusina
    correctAnswerIndex: 0
  - questionText: Bakit parang ika'y tugluyin? May sakit ka ga o sadyang tamad ka
      laang?" Ano ang ibig sabihin ng tugluyin?
    choices:
    - 'Masigla '
    - Matangkad
    - Maingay
    - Malungkot
    correctAnswerIndex: 1
  - questionText: Pihado, mamura ka ng head nurse kapag pumasok kang yapak d'yan
      sa loob!" Ano ang yapak?
    choices:
    - Marumi ang damit
    - Basang-basa
    - Nakapaa
    - Maingay ang lakad
    correctAnswerIndex: 2
  - questionText: O ayan na ang tita mo. Pumirme ka d'yan at huwag kang mag-litar
      sa bawal na area." Ano ang litar?
    choices:
    - Gumala-gala
    - Mag-ingay
    - Kumain
    - Mag-usap
    correctAnswerIndex: 0
  tutorialQuestions: []
  quizPanel: {fileID: 1234853985}
  questionText: {fileID: 1234853984}
