  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager
  questions:
  - questionText: Nurse, bakit ang daming guyam dine sa lamesa? Paki-linis nga agad."
      Ano ang guyam?
    choices:
    - Langgam
    - Ipis
    - Lamok
    - Langaw
    correctAnswerIndex: 0
  - questionText: Ika'y mukhang liyo. Matagal ka na bang nag-aantay dine sa mainit?"
      Ano ang liyo?
    choices:
    - Gutom
    - Galit
    - Uhaw
    - Hilo
    correctAnswerIndex: 3
  - questionText: Tingnan ko nga ang iyong busilig. Mukhang puyat ka rin katulad
      ng mga nurse ko." Ano ang busilig?
    choices:
    - Tenga
    - Mata
    - Ilong
    - Labi
    correctAnswerIndex: 1
  - questionText: Huwag kang mag-balais, magiging alwan din ang pakiramdam mo kapag
      nakapagpahinga ka na." Ano ang alwan?
    choices:
    - Mabigat
    - Masakit
    - Madali/Magaan
    - Malabo
    correctAnswerIndex: 2
  - questionText: Sige na, mag-pulas na kayo bago pa dagsain ng maraming tao ang
      lobby." Ano ang ibig sabihin ng pulas?
    choices:
    - Matulog
    - Pumasok
    - Umalis
    - Kumain
    correctAnswerIndex: 2
  tutorialQuestions: []
