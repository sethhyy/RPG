  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 69c5666ef3490414ba3aae7b451a283a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager
  questions:
  - questionText: Suki! Bili na kayo ng alid at hawot! Sariwa are, kaka-agdon laang
      galing sa dagat!" Ano ang ibig sabihin ng agdon?
    choices:
    - Nabulok
    - Nakarating/Dumating
    - Nawala
    - Nahulog
    correctAnswerIndex: 1
  - questionText: Huwag kang mag-asbag na wala kang pera, puge! Mura laang are."
      Ano ang ibig sabihin ng asbag?
    choices:
    - Magmura
    - Magmayabang
    - Magmadali
    - Magreklamo
    correctAnswerIndex: 1
  - questionText: Tingnan mo areng bilot ko, kasama ko sa pagtitinda. Huwag mong
      balibangin ng bato at baka ka kagatin!" Ano ang bilot?
    choices:
    - Pusa
    - Tuta
    - Manok
    - Ibon
    correctAnswerIndex: 1
  - questionText: Ay, bakit parang ika'y bangenge? Napuyat ka ga kagabi?" Ano ang
      ibig sabihin ng bangenge?
    choices:
    - Antok na antok
    - Galit na galit
    - Gutom na gutom
    - Masayang-masaya
    correctAnswerIndex: 0
  - questionText: O heto ang balatong mo. Isilid mo sa iyong lukbutan ang sukli para
      hindi mawala." Ano ang lukbutan?
    choices:
    - Basket
    - Bulsa
    - Kamay
    - Plastic bag
    correctAnswerIndex: 1
  tutorialQuestions: []
  quizPanel: {fileID: 297432157}
  questionText: {fileID: 297432156}
